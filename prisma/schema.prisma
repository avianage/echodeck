generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String             @id @default(cuid())
  email                 String?            @unique
  username              String?            @unique
  displayName           String?
  image                 String?
  createdAt             DateTime           @default(now())
  usernameUpdatedAt     DateTime?
  platformRole          PlatformRole       @default(MEMBER)
  isBanned              Boolean            @default(false)
  banReason             String?
  bannedUntil           DateTime?
  bannedAt              DateTime?
  spotifyConnected      Boolean            @default(false)
  spotifyAccessToken    String?
  spotifyRefreshToken   String?
  spotifyTokenExpiresAt DateTime?
  deletedAt             DateTime?
  provider              Provider?
  isPublic              Boolean            @default(true)
  emailVerified         DateTime?
  name                  String?
  allowFriendRequests   Boolean            @default(true)
  partyCode             String?            @unique @default(uuid())
  accounts              Account[]
  currentStream         CurrentStream?
  favoritedBy           Favorite[]         @relation("targetUser")
  favorites             Favorite[]         @relation("userFavorites")
  receivedRequests      Friendship[]       @relation("ReceivedRequests")
  sentRequests          Friendship[]       @relation("SentRequests")
  listeningActivity     ListeningActivity?
  sessions              Session[]
  sessionMembers        SessionMember[]
  added                 Stream[]           @relation("addedBy")
  streams               Stream[]           @relation("user")
  pendingApprovals      StreamAccess[]     @relation("streamer")
  accessGrants          StreamAccess[]     @relation("viewer")
  upvotes               Upvote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Stream {
  id            String         @id @default(cuid())
  type          StreamType
  url           String
  extractedId   String
  smallImg      String         @default("")
  title         String         @default("")
  bigImg        String         @default("")
  active        Boolean        @default(true)
  played        Boolean        @default(false)
  playedTs      DateTime?
  createdAt     DateTime       @default(now())
  isPublic      Boolean        @default(false)
  isLive        Boolean        @default(false)
  startedAt     DateTime?
  endedAt       DateTime?
  viewerCount   Int            @default(0)
  userId        String
  addedById     String
  currentStream CurrentStream?
  addedBy       User           @relation("addedBy", fields: [addedById], references: [id])
  user          User           @relation("user", fields: [userId], references: [id])
  upvotes       Upvote[]
}

model CurrentStream {
  userId      String   @id
  streamId    String?  @unique
  currentTime Float    @default(0)
  isPaused    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  viewerCount Int      @default(0)
  genre       String?
  title       String?
  stream      Stream?  @relation(fields: [streamId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SessionMember {
  id          String     @id @default(cuid())
  userId      String
  creatorId   String
  role        StreamRole @default(MEMBER)
  joinedAt    DateTime   @default(now())
  isBanned    Boolean    @default(false)
  banReason   String?
  bannedUntil DateTime?
  bannedAt    DateTime?
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
}

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  addressee   User         @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)
  requester   User         @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

model ListeningActivity {
  id        String   @id @default(cuid())
  userId    String   @unique
  creatorId String
  songTitle String?
  songId    String?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  favoriteId String
  createdAt  DateTime @default(now())
  favorite   User     @relation("targetUser", fields: [favoriteId], references: [id])
  user       User     @relation("userFavorites", fields: [userId], references: [id])

  @@unique([userId, favoriteId])
}

model StreamAccess {
  id         String       @id @default(cuid())
  streamerId String
  viewerId   String
  status     AccessStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  streamer   User         @relation("streamer", fields: [streamerId], references: [id])
  viewer     User         @relation("viewer", fields: [viewerId], references: [id])

  @@unique([streamerId, viewerId])
}

model Upvote {
  id       String @id @default(cuid())
  userId   String
  streamId String
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, streamId])
}

model StreamEvent {
  id        String          @id @default(cuid())
  creatorId String
  type      StreamEventType
  message   String
  createdAt DateTime        @default(now())
  expiresAt DateTime
}

enum PlatformRole {
  MEMBER
  CREATOR
  OWNER
}

enum StreamRole {
  MODERATOR
  MEMBER
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum StreamType {
  Spotify
  Youtube
}

enum Provider {
  Google
  Spotify
}

enum AccessStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StreamEventType {
  USER_BANNED_PLATFORM
  USER_BANNED_STREAM
  USER_TIMED_OUT_PLATFORM
  USER_TIMED_OUT_STREAM
  CREATOR_ROLE_REVOKED
  STREAM_FORCE_CLOSED
  MOD_PROMOTED
  MOD_DEMOTED
  SONG_REMOVED_BY_MOD
  SONG_SKIPPED_BY_CREATOR
}

model MaintenanceMode {
    id          String    @id @default("singleton") // always one record
    isActive    Boolean   @default(false)
    message     String?
    startedAt   DateTime?
    endsAt      DateTime? // null = indefinite
    updatedBy   String    // owner userId
}
