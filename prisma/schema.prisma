// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String?   @unique
  username              String?   @unique
  displayName           String?
  image                 String?
  createdAt             DateTime  @default(now())

  // Username update cooldown
  usernameUpdatedAt     DateTime?

  // Platform-level RBAC
  platformRole          PlatformRole @default(MEMBER)

  // Platform ban/timeout
  isBanned              Boolean   @default(false)
  banReason             String?
  bannedUntil           DateTime?

  // Spotify linking (separate from OAuth sign-in)
  spotifyConnected      Boolean   @default(false)
  spotifyAccessToken    String?
  spotifyRefreshToken   String?
  spotifyTokenExpiresAt DateTime?

  // Account deletion soft marker
  deletedAt             DateTime?

  // Legacy fields (kept for backwards compatibility)
  provider              Provider?
  isPublic              Boolean   @default(true)

  // Relations
  accounts              Account[]
  sessions              Session[]
  streams               Stream[]        @relation("user")
  added                 Stream[]        @relation("addedBy")
  upvotes               Upvote[]
  favorites             Favorite[]      @relation("userFavorites")
  favoritedBy           Favorite[]      @relation("targetUser")
  pendingApprovals      StreamAccess[]  @relation("streamer")
  accessGrants          StreamAccess[]  @relation("viewer")
  sessionMembers        SessionMember[]
  sentRequests          Friendship[]    @relation("SentRequests")
  receivedRequests      Friendship[]    @relation("ReceivedRequests")
  listeningActivity     ListeningActivity?
  currentStream         CurrentStream?
}

enum PlatformRole {
  MEMBER
  CREATOR
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Stream ───────────────────────────────────────────────────────────────────

model Stream {
  id          String     @id @default(cuid())
  type        StreamType
  url         String
  extractedId String
  smallImg    String     @default("")
  title       String     @default("")
  bigImg      String     @default("")
  active      Boolean    @default(true)
  played      Boolean    @default(false)
  playedTs    DateTime?
  createdAt   DateTime   @default(now())

  // Discovery / live fields
  isPublic    Boolean    @default(false)
  isLive      Boolean    @default(false)
  startedAt   DateTime?
  endedAt     DateTime?
  viewerCount Int        @default(0)

  userId    String
  addedById String
  user      User   @relation(fields: [userId], references: [id], name: "user")
  addedBy   User   @relation(fields: [addedById], references: [id], name: "addedBy")

  upvotes       Upvote[]
  currentStream CurrentStream?
}

model CurrentStream {
  userId      String   @id
  streamId    String?  @unique
  stream      Stream?  @relation(fields: [streamId], references: [id])
  currentTime Float    @default(0)
  isPaused    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  viewerCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Session Members (per-stream RBAC + scoped bans) ─────────────────────────

model SessionMember {
  id        String     @id @default(cuid())
  userId    String
  creatorId String
  role      StreamRole @default(MEMBER)
  joinedAt  DateTime   @default(now())

  isBanned    Boolean   @default(false)
  banReason   String?
  bannedUntil DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
}

enum StreamRole {
  MODERATOR
  MEMBER
}

// ─── Friends ──────────────────────────────────────────────────────────────────

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// ─── Listening Activity ───────────────────────────────────────────────────────

model ListeningActivity {
  id        String   @id @default(cuid())
  userId    String   @unique
  creatorId String
  songTitle String?
  songId    String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Legacy / Existing Models ─────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  favoriteId String
  createdAt  DateTime @default(now())

  user     User @relation("userFavorites", fields: [userId], references: [id])
  favorite User @relation("targetUser", fields: [favoriteId], references: [id])

  @@unique([userId, favoriteId])
}

model StreamAccess {
  id         String       @id @default(cuid())
  streamerId String
  viewerId   String
  status     AccessStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  streamer User @relation("streamer", fields: [streamerId], references: [id])
  viewer   User @relation("viewer", fields: [viewerId], references: [id])

  @@unique([streamerId, viewerId])
}

model Upvote {
  id       String @id @default(cuid())
  userId   String
  streamId String

  user   User   @relation(fields: [userId], references: [id])
  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@unique([userId, streamId])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum StreamType {
  Spotify
  Youtube
}

enum Provider {
  Google
  Spotify
}

enum AccessStatus {
  PENDING
  APPROVED
  REJECTED
}